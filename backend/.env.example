# Copy this file to .env and fill in your keys.
# The app works without any keys (uses unauthenticated Google Books quota).

PORT=3001

# Google Books API — free key from https://console.cloud.google.com
GOOGLE_BOOKS_API_KEY=

# Israeli National Library — improves Hebrew book search
NLI_API_KEY=

# Anthropic Claude — required only for the shelf photo scanner
ANTHROPIC_API_KEY=
